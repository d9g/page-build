# ============================================================
# 公众号排版小程序 — 环境变量配置模板
# 复制此文件为 .env 并填入真实值：cp .env.example .env
# ============================================================

# ============ 域名配置 ============
DOMAIN=pb.d9g.com.cn

# ============ 智谱 AI（GLM-4-Flash 免费模型）============
# 在 https://open.bigmodel.cn/ 注册获取
ZHIPU_API_KEY=your_zhipu_api_key_here

# ============ 微信小程序 ============
# 在微信公众平台 → 开发管理 → 开发设置中获取
MINI_APP_ID=your_mini_app_id
MINI_APP_SECRET=your_mini_app_secret

# ============ 公众号 A ============
ACCOUNT_A_ID=account_a
ACCOUNT_A_NAME=老杨说事
ACCOUNT_A_DESC=深度好文精选
ACCOUNT_A_APP_ID=wx_aaa
ACCOUNT_A_APP_SECRET=secret_aaa
ACCOUNT_A_TOKEN=token_aaa
ACCOUNT_A_AES_KEY=aes_key_aaa
ACCOUNT_A_AVATAR=/static/avatars/a.png
ACCOUNT_A_QRCODE=/static/qrcodes/a.png

# ============ 公众号 B（可选，按需添加）============
ACCOUNT_B_ID=account_b
ACCOUNT_B_NAME=老杨生活
ACCOUNT_B_DESC=生活美学分享
ACCOUNT_B_APP_ID=wx_bbb
ACCOUNT_B_APP_SECRET=secret_bbb
ACCOUNT_B_TOKEN=token_bbb
ACCOUNT_B_AES_KEY=aes_key_bbb
ACCOUNT_B_AVATAR=/static/avatars/b.png
ACCOUNT_B_QRCODE=/static/qrcodes/b.png

# ============ 公众号 C（可选，按需添加）============
# ACCOUNT_C_ID=account_c
# ACCOUNT_C_NAME=老杨日签
# ACCOUNT_C_DESC=每日正能量签到
# ACCOUNT_C_APP_ID=wx_ccc
# ACCOUNT_C_APP_SECRET=secret_ccc
# ACCOUNT_C_TOKEN=token_ccc
# ACCOUNT_C_AES_KEY=aes_key_ccc
# ACCOUNT_C_AVATAR=/static/avatars/c.png
# ACCOUNT_C_QRCODE=/static/qrcodes/c.png

# ============ Redis ============
REDIS_URL=redis://localhost:6379/0

# ============ 管理密钥 ============
# 用于管理接口鉴权，请设置一个复杂的随机字符串
ADMIN_SECRET_KEY=your_admin_secret_key_here

# ============ 服务配置 ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false
