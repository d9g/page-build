/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 主题色变量 */
.primary-color { color: #07C160; }
.primary-bg { background-color: #07C160; }

/* 常用容器 */
.container {
  padding: 24rpx;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #07C160, #05a14a);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}
.btn-primary[disabled] {
  opacity: 0.5;
  background: #cccccc;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
