/* 结果页样式 */
.loading-wrap {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; min-height: 60vh;
}
.loading-spinner {
  width: 60rpx; height: 60rpx; border: 4rpx solid #e0e0e0;
  border-top-color: #07C160; border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { margin-top: 20rpx; font-size: 28rpx; color: #999; }
.loading-hint { margin-top: 8rpx; font-size: 22rpx; color: #ccc; }

/* 进度条 */
.progress-bar {
  width: 400rpx; height: 6rpx; background: #e8e8e8;
  border-radius: 3rpx; margin-top: 20rpx; overflow: hidden;
}
.progress-fill {
  height: 100%; background: linear-gradient(90deg, #07C160, #05d66e);
  border-radius: 3rpx; transition: width 0.3s ease;
}

/* 预览区 */
.preview-area { max-height: 56vh; }
.preview-card {
  background: #fff; border-radius: 16rpx; padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* 底部工具栏 */
.bottom-bar { padding-top: 20rpx; }
.section-title { font-size: 26rpx; color: #666; margin-bottom: 12rpx; }

/* Slider 快捷调整 */
.slider-group { background: #fff; border-radius: 12rpx; padding: 16rpx 24rpx; margin-bottom: 20rpx; }
.slider-item { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.slider-item:last-child { margin-bottom: 0; }
.slider-label { font-size: 24rpx; color: #999; width: 60rpx; flex-shrink: 0; }
.slider { flex: 1; }

/* 主题选择 */
.theme-scroll { white-space: nowrap; margin-bottom: 20rpx; }
.theme-list { display: inline-flex; gap: 16rpx; }
.theme-item {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 12rpx 24rpx; border-radius: 32rpx;
  background: #f5f5f5; font-size: 26rpx; color: #666;
  border: 2rpx solid transparent;
}
.theme-item.active { border-color: #07C160; background: #f0faf4; color: #07C160; }
.theme-item.premium::after { content: '👑'; margin-left: 4rpx; font-size: 20rpx; }
.theme-dot { width: 20rpx; height: 20rpx; border-radius: 50%; }

/* 操作按钮 */
.action-row { margin-bottom: 16rpx; }
.btn-secondary {
  background: #f5f5f5; color: #666; border: none;
  border-radius: 16rpx; padding: 24rpx 0; font-size: 30rpx;
  text-align: center; width: 100%;
}
