/* 首页样式 */
.header {
  text-align: center;
  padding: 40rpx 0 24rpx;
}
.logo { font-size: 72rpx; display: block; margin-bottom: 12rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #333; display: block; }
.subtitle { font-size: 26rpx; color: #999; display: block; margin-top: 8rpx; }

/* 输入区 */
.input-card { padding: 0; overflow: hidden; }
.input-area {
  width: 100%;
  min-height: 400rpx;
  padding: 28rpx;
  font-size: 30rpx;
  line-height: 1.7;
  color: #333;
  box-sizing: border-box;
}
.toolbar {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #fafafa;
}
.tool-btn {
  font-size: 26rpx;
  color: #07C160;
  margin-right: 32rpx;
  padding: 8rpx 0;
}
.word-count {
  margin-left: auto;
  font-size: 24rpx;
  color: #bbb;
}

/* 草稿提示 */
.draft-tip {
  background: #fff8e6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #666;
}
.draft-actions { margin-top: 12rpx; display: flex; gap: 24rpx; }
.draft-btn { color: #07C160; font-weight: bold; }
.draft-btn.dismiss { color: #999; font-weight: normal; }

/* 排版按钮 */
.layout-btn { margin: 32rpx 0; }

/* 提示文字 */
.hint { display: block; text-align: center; font-size: 24rpx; color: #f5222d; }
