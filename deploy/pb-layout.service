# systemd 服务配置
# 复制到 /etc/systemd/system/pb-layout.service
# 将路径替换为实际的项目部署路径

[Unit]
Description=公众号排版小程序后端
After=network.target redis.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/pb-layout/backend
ExecStart=/opt/pb-layout/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PATH=/opt/pb-layout/backend/.venv/bin

[Install]
WantedBy=multi-user.target
